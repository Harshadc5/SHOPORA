{
  "name": "aiora-js-tag",
  "version": "0.1.0",
  "description": "AIORA JS Tag — passive coordination failure signal collector",
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:browser": "playwright test tests/browser",
    "build": "esbuild src/tag.js --bundle --minify --outfile=dist/tag.min.js"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@vitest/coverage-v8": "^1.0.0",
    "esbuild": "^0.20.0",
    "jsdom": "^24.0.0",
    "playwright": "^1.61.1",
    "vitest": "^1.0.0"
  }
}
